# Copy to .env and adjust if the default ports clash with something local.
#   cp .env.example .env

# Timezone for message timestamps in the UI
TZ=UTC

# Host ports (left side = your machine). Change these if 8025/1025/1110 are taken.
MP_UI_PORT=8025
MP_SMTP_PORT=1025
MP_POP3_PORT=1110

# Max messages Mailpit keeps before rotating out the oldest
MP_MAX_MESSAGES=5000

# POP3 credentials Mendix uses to RETRIEVE mail (format: user:pass)
MP_POP3_AUTH=test:test
